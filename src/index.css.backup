:root{
  --bg:#f5f6f9; --card:#fff; --ink:#13171e; --muted:#6f7884;
  --line:#e9ecf2; --accent:#ea580c; --accent-d:#c2410c; --soft:#fff2e9;
  --shadow:0 1px 3px rgba(19,23,30,.04),0 8px 24px rgba(19,23,30,.06);
  --shadow-lg:0 12px 40px rgba(19,23,30,.14);
  --radius:18px;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;background:var(--bg);color:var(--ink);-webkit-font-smoothing:antialiased;line-height:1.45}
button{font-family:inherit}

/* HEADER */
.top{position:sticky;top:0;z-index:30;background:rgba(255,255,255,.85);backdrop-filter:saturate(180%) blur(14px);border-bottom:1px solid var(--line);display:flex;align-items:center;justify-content:space-between;gap:14px;padding:15px 26px}
.logo{font-weight:800;font-size:22px;letter-spacing:-.7px;display:flex;align-items:center;gap:8px}
.logo b{color:var(--accent)}
.acct{display:flex;align-items:center;gap:10px;margin-left:auto}
.acct .mail{font-size:13px;color:var(--muted);font-weight:600;max-width:170px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.sell{background:var(--accent);color:#fff;border:0;border-radius:999px;padding:11px 22px;font-weight:700;font-size:15px;cursor:pointer;box-shadow:0 6px 18px rgba(234,88,12,.30);transition:transform .15s,box-shadow .15s,background .15s}
.sell:hover{background:var(--accent-d);transform:translateY(-1px);box-shadow:0 10px 24px rgba(234,88,12,.38)}
.sell:active{transform:translateY(0)}
.logout{background:#fff;border:1px solid var(--line);color:var(--muted);border-radius:999px;padding:10px 17px;font-weight:700;font-size:14px;cursor:pointer;transition:all .15s}
.logout:hover{border-color:var(--accent);color:var(--accent)}

/* HERO */
.hero{position:relative;overflow:hidden;text-align:center;padding:58px 24px 52px;background:radial-gradient(900px 360px at 50% -40%,#ffe2cf 0%,transparent 70%),linear-gradient(180deg,#fff8f3,#f5f6f9)}
.hero::before{content:"";position:absolute;inset:0;background:radial-gradient(420px 200px at 12% 110%,rgba(234,88,12,.10),transparent 70%),radial-gradient(420px 200px at 88% 0%,rgba(234,88,12,.08),transparent 70%);pointer-events:none}
.hero h1{position:relative;font-size:38px;font-weight:800;letter-spacing:-1.2px;line-height:1.1;margin-bottom:12px}
.hero p{position:relative;color:var(--muted);font-size:17px;margin-bottom:28px}
.searchbar{position:relative;max-width:640px;margin:0 auto;display:flex;gap:8px;background:#fff;border:1px solid var(--line);border-radius:999px;padding:8px 8px 8px 22px;box-shadow:var(--shadow);transition:box-shadow .2s,border-color .2s}
.searchbar:focus-within{border-color:var(--accent);box-shadow:0 0 0 4px rgba(234,88,12,.12),var(--shadow)}
.searchbar input{flex:1;border:0;outline:none;font-size:15.5px;background:transparent;color:var(--ink)}
.searchbar button{background:var(--accent);color:#fff;border:0;border-radius:999px;padding:12px 26px;font-weight:700;font-size:15px;cursor:pointer;transition:background .15s}
.searchbar button:hover{background:var(--accent-d)}

/* CHIPS */
.chips{display:flex;gap:10px;overflow-x:auto;padding:22px 26px;max-width:1240px;margin:0 auto;scrollbar-width:none}
.chips::-webkit-scrollbar{display:none}
.chip{border:1px solid var(--line);background:#fff;color:#4a525e;border-radius:999px;padding:9px 18px;font-size:14px;font-weight:600;cursor:pointer;white-space:nowrap;transition:all .15s}
.chip:hover{border-color:var(--accent);color:var(--accent);transform:translateY(-1px)}
.chip.on{background:var(--ink);color:#fff;border-color:var(--ink);box-shadow:0 6px 16px rgba(19,23,30,.18)}

/* GRID */
.wrap{max-width:1240px;margin:0 auto;padding:6px 26px 80px}
.wrap h2{font-size:23px;font-weight:800;letter-spacing:-.5px;margin-bottom:4px}
.wrap .cnt{color:var(--muted);font-size:14.5px;margin-bottom:24px}
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(238px,1fr));gap:20px}

/* CARD */
.card{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;cursor:pointer;box-shadow:var(--shadow);transition:transform .2s cubic-bezier(.2,.7,.3,1),box-shadow .2s;animation:fadeUp .4s both}
.card:hover{transform:translateY(-6px);box-shadow:var(--shadow-lg)}
.img{position:relative;height:172px;display:flex;align-items:center;justify-content:center;font-size:62px;background:linear-gradient(135deg,#fff6ee,#ffe7d4);transition:transform .3s}
.card:hover .img{transform:scale(1.04)}
.cond{position:absolute;top:12px;left:12px;background:rgba(255,255,255,.94);backdrop-filter:blur(4px);font-size:12px;font-weight:700;padding:5px 11px;border-radius:999px;box-shadow:0 2px 8px rgba(0,0,0,.08)}
.body{padding:14px 15px 16px}
.price{font-size:20px;font-weight:800;color:var(--accent);letter-spacing:-.4px}
.title{font-size:14.5px;color:#252d38;font-weight:600;margin:5px 0 12px;line-height:1.32;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;min-height:38px}
.seller{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.badge{font-size:10.5px;font-weight:800;padding:4px 9px;border-radius:7px;text-transform:uppercase;letter-spacing:.4px}
.badge.pro{background:var(--soft);color:var(--accent-d)}
.badge.part{background:#eef1f6;color:#5b6471}
.sname{font-size:13px;color:var(--muted);font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.loc{display:flex;align-items:center;gap:4px;font-size:12.5px;color:var(--muted)}
.empty{text-align:center;color:var(--muted);padding:70px 0;font-size:15px}

/* DETAIL */
.detail-back{background:none;border:0;color:var(--muted);font-size:15px;font-weight:700;cursor:pointer;padding:20px 26px;display:flex;align-items:center;gap:6px;transition:color .15s}
.detail-back:hover{color:var(--accent)}
.detail{max-width:780px;margin:0 auto;padding:0 26px 80px;animation:fadeUp .4s both}
.detail-img{height:320px;border-radius:24px;display:flex;align-items:center;justify-content:center;font-size:140px;background:linear-gradient(135deg,#fff6ee,#ffe7d4);margin-bottom:24px;position:relative;box-shadow:var(--shadow)}
.detail-img .cond{top:18px;left:18px;font-size:13px}
.detail-price{font-size:34px;font-weight:800;color:var(--accent);letter-spacing:-.6px}
.detail-title{font-size:25px;font-weight:800;letter-spacing:-.5px;margin:6px 0 20px}
.detail-meta{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:24px}
.tag{background:#fff;border:1px solid var(--line);border-radius:11px;padding:10px 15px;font-size:14px;font-weight:600;color:#2b3543;box-shadow:var(--shadow)}
.detail-seller{display:flex;align-items:center;gap:13px;background:#fff;border:1px solid var(--line);border-radius:18px;padding:17px;margin-bottom:24px;box-shadow:var(--shadow)}
.av{width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent-d));color:#fff;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:20px;box-shadow:0 6px 16px rgba(234,88,12,.30)}
.detail-seller .nm{font-weight:700;font-size:16px}
.detail-actions{display:flex;gap:12px}
.btn-contact{flex:1;background:var(--accent);color:#fff;border:0;border-radius:14px;padding:16px;font-weight:800;font-size:16px;cursor:pointer;box-shadow:0 8px 22px rgba(234,88,12,.30);transition:transform .15s,background .15s}
.btn-contact:hover{background:var(--accent-d);transform:translateY(-1px)}
.btn-del{background:#fff;border:1px solid #fecaca;color:#dc2626;border-radius:14px;padding:16px 24px;font-weight:800;font-size:15px;cursor:pointer;transition:background .15s}
.btn-del:hover{background:#fef2f2}

/* MODALS */
.overlay{position:fixed;inset:0;background:rgba(13,17,23,.55);backdrop-filter:blur(4px);display:flex;align-items:center;justify-content:center;z-index:50;padding:20px;animation:overlayIn .2s both}
.modal{background:#fff;border-radius:24px;width:100%;max-width:450px;padding:30px;box-shadow:0 30px 70px rgba(0,0,0,.30);max-height:90vh;overflow-y:auto;animation:pop .28s cubic-bezier(.2,.8,.3,1) both}
.modal h3{font-size:23px;font-weight:800;letter-spacing:-.5px;margin-bottom:4px}
.modal .sub{color:var(--muted);font-size:14px;margin-bottom:22px}
.field{margin-bottom:14px}
.field label{display:block;font-size:13px;font-weight:700;color:#2b3543;margin-bottom:6px}
.field input,.field select{width:100%;border:1px solid var(--line);border-radius:13px;padding:13px 15px;font-size:15px;outline:none;background:#fff;color:var(--ink);transition:border-color .15s,box-shadow .15s}
.field input:focus,.field select:focus{border-color:var(--accent);box-shadow:0 0 0 4px rgba(234,88,12,.12)}
.row2{display:flex;gap:12px}
.row2 .field{flex:1}
.check{display:flex;align-items:center;gap:9px;margin-bottom:18px;cursor:pointer;font-size:14px;font-weight:600;color:#2b3543}
.check input{width:18px;height:18px;accent-color:var(--accent);cursor:pointer}
.btn-primary{width:100%;background:var(--accent);color:#fff;border:0;border-radius:14px;padding:15px;font-weight:800;font-size:16px;cursor:pointer;box-shadow:0 8px 22px rgba(234,88,12,.30);transition:transform .15s,background .15s}
.btn-primary:hover{background:var(--accent-d);transform:translateY(-1px)}
.btn-primary:disabled{opacity:.55;cursor:not-allowed;box-shadow:none;transform:none}
.modal-x{float:right;background:none;border:0;font-size:26px;color:var(--muted);cursor:pointer;line-height:1;margin:-8px -8px 0 0;transition:color .15s}
.modal-x:hover{color:var(--ink)}
.switch{text-align:center;margin-top:18px;font-size:14px;color:var(--muted)}
.switch b{color:var(--accent);cursor:pointer;font-weight:700}
.err{background:#fef2f2;color:#b91c1c;border-radius:11px;padding:11px 13px;font-size:13px;font-weight:600;margin-bottom:14px}

@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
@keyframes pop{from{opacity:0;transform:scale(.94) translateY(10px)}to{opacity:1;transform:scale(1) translateY(0)}}
@keyframes overlayIn{from{opacity:0}to{opacity:1}}

@media(max-width:640px){
  .top{padding:13px 16px}
  .acct .mail{display:none}
  .hero{padding:40px 18px 38px}
  .hero h1{font-size:27px}
  .hero p{font-size:15px}
  .wrap{padding:6px 16px 60px}
  .chips{padding:18px 16px}
  .grid{grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:13px}
  .img{height:130px;font-size:46px}
  .detail-img{height:230px;font-size:100px}
  .detail-actions{flex-direction:column}
}
.img img,.detail-img img{width:100%;height:100%;object-fit:cover}
.img{overflow:hidden}
.detail-img{overflow:hidden}
.photo-drop{border:2px dashed var(--line);border-radius:14px;padding:22px;text-align:center;cursor:pointer;transition:border-color .15s,background .15s;margin-bottom:14px}
.photo-drop:hover{border-color:var(--accent);background:var(--soft)}
.photo-drop .ico{font-size:30px;margin-bottom:6px}
.photo-drop .txt{font-size:13.5px;color:var(--muted);font-weight:600}
.photo-prev{position:relative;margin-bottom:14px;border-radius:14px;overflow:hidden;height:170px}
.photo-prev img{width:100%;height:100%;object-fit:cover}
.photo-prev .rm{position:absolute;top:8px;right:8px;background:rgba(0,0,0,.6);color:#fff;border:0;width:30px;height:30px;border-radius:50%;font-size:16px;cursor:pointer;line-height:1}
.sell{padding:13px 28px;font-size:16px}
.fav-btn{position:absolute;top:10px;right:10px;background:rgba(255,255,255,.92);backdrop-filter:blur(4px);border:0;width:38px;height:38px;border-radius:50%;font-size:19px;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 10px rgba(0,0,0,.12);transition:transform .15s;z-index:2}
.fav-btn:hover{transform:scale(1.12)}
.fav-btn.on{animation:pop .3s}
.filters{max-width:1240px;margin:0 auto;padding:4px 26px 10px;display:flex;flex-wrap:wrap;gap:10px;align-items:center}
.filters .fgroup{display:flex;align-items:center;gap:6px}
.filters input,.filters select{border:1px solid var(--line);border-radius:10px;padding:9px 12px;font-size:14px;outline:none;background:#fff;color:var(--ink);font-weight:600}
.filters input{width:92px}
.filters input:focus,.filters select:focus{border-color:var(--accent)}
.filters .lbl{font-size:13px;font-weight:700;color:var(--muted)}
.filters .reset{background:none;border:0;color:var(--accent);font-weight:700;font-size:14px;cursor:pointer;margin-left:auto}
.viewtabs{max-width:1240px;margin:0 auto;padding:14px 26px 0;display:flex;gap:8px}
.vtab{background:#fff;border:1px solid var(--line);color:#4a525e;border-radius:999px;padding:9px 18px;font-size:14px;font-weight:700;cursor:pointer;transition:all .15s}
.vtab.on{background:var(--ink);color:#fff;border-color:var(--ink)}
.vtab:hover{border-color:var(--accent)}
@media(max-width:640px){.filters{padding:4px 16px 10px}.filters input{width:78px}.viewtabs{padding:12px 16px 0}}
.btn-edit{background:#fff;border:1px solid var(--line);color:#2b3543;border-radius:14px;padding:16px 24px;font-weight:800;font-size:15px;cursor:pointer;transition:all .15s}
.btn-edit:hover{border-color:var(--accent);color:var(--accent)}
.gallery{margin-bottom:24px}
.gallery-main{height:340px;border-radius:24px;overflow:hidden;position:relative;background:linear-gradient(135deg,#fff6ee,#ffe7d4);display:flex;align-items:center;justify-content:center;font-size:140px;box-shadow:var(--shadow)}
.gallery-main img{width:100%;height:100%;object-fit:cover}
.gallery-main .cond{top:18px;left:18px;font-size:13px}
.thumbs{display:flex;gap:10px;margin-top:12px;overflow-x:auto;scrollbar-width:none}
.thumbs::-webkit-scrollbar{display:none}
.thumb{width:74px;height:74px;border-radius:12px;overflow:hidden;cursor:pointer;flex-shrink:0;border:2px solid transparent;transition:border-color .15s}
.thumb img{width:100%;height:100%;object-fit:cover}
.thumb.on{border-color:var(--accent)}
.previews{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px}
.prev-mini{position:relative;width:72px;height:72px;border-radius:10px;overflow:hidden}
.prev-mini img{width:100%;height:100%;object-fit:cover}
.prev-mini .rm{position:absolute;top:3px;right:3px;background:rgba(0,0,0,.6);color:#fff;border:0;width:22px;height:22px;border-radius:50%;font-size:13px;cursor:pointer;line-height:1;display:flex;align-items:center;justify-content:center}
.add-more{width:72px;height:72px;border:2px dashed var(--line);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:24px;color:var(--muted);cursor:pointer;transition:all .15s}
.add-more:hover{border-color:var(--accent);color:var(--accent)}
.chat-overlay{position:fixed;inset:0;background:rgba(13,17,23,.55);backdrop-filter:blur(4px);display:flex;align-items:flex-end;justify-content:center;z-index:60;padding:0}
.chat-box{background:#fff;width:100%;max-width:560px;height:80vh;border-radius:24px 24px 0 0;display:flex;flex-direction:column;box-shadow:0 -10px 50px rgba(0,0,0,.3);animation:slideUp .3s cubic-bezier(.2,.8,.3,1) both}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.chat-head{display:flex;align-items:center;gap:12px;padding:18px 20px;border-bottom:1px solid var(--line)}
.chat-head .av{width:42px;height:42px;font-size:18px}
.chat-head .ci{flex:1;min-width:0}
.chat-head .ct{font-weight:800;font-size:16px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.chat-head .cs{font-size:13px;color:var(--muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.chat-head .cx{background:none;border:0;font-size:26px;color:var(--muted);cursor:pointer;line-height:1}
.chat-body{flex:1;overflow-y:auto;padding:18px 20px;display:flex;flex-direction:column;gap:10px;background:#f7f8fa}
.msg{max-width:75%;padding:11px 15px;border-radius:18px;font-size:14.5px;line-height:1.4;word-wrap:break-word}
.msg.mine{align-self:flex-end;background:var(--accent);color:#fff;border-bottom-right-radius:5px}
.msg.theirs{align-self:flex-start;background:#fff;color:var(--ink);border:1px solid var(--line);border-bottom-left-radius:5px}
.msg .t{display:block;font-size:10.5px;opacity:.6;margin-top:3px}
.chat-empty{text-align:center;color:var(--muted);font-size:14px;margin:auto;padding:20px}
.chat-input{display:flex;gap:9px;padding:14px 16px;border-top:1px solid var(--line)}
.chat-input input{flex:1;border:1px solid var(--line);border-radius:999px;padding:13px 18px;font-size:15px;outline:none}
.chat-input input:focus{border-color:var(--accent)}
.chat-input button{background:var(--accent);color:#fff;border:0;border-radius:50%;width:46px;height:46px;font-size:19px;cursor:pointer;flex-shrink:0}
.chat-input button:disabled{opacity:.5;cursor:not-allowed}
.inbox-item{display:flex;align-items:center;gap:13px;padding:14px 16px;border:1px solid var(--line);border-radius:16px;margin-bottom:10px;cursor:pointer;background:#fff;transition:all .15s}
.inbox-item:hover{border-color:var(--accent);transform:translateY(-1px);box-shadow:var(--shadow)}
.inbox-item .ii{flex:1;min-width:0}
.inbox-item .it{font-weight:700;font-size:15px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.inbox-item .il{font-size:13px;color:var(--muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
@media(max-width:640px){.chat-box{height:88vh}}
